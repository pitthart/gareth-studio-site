<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Netlify Forms</title>
  </head>
  <body>
    <!-- This page exists ONLY so Netlify can detect the form at deploy time -->
    <form name="artwork-inquiry" method="POST" data-netlify="true" data-netlify-honeypot="bot-field">
      <input type="hidden" name="form-name" value="artwork-inquiry" />
      <p style="display:none;">
        <label>Don’t fill this out: <input name="bot-field" /></label>
      </p>

      <input type="text" name="artworkTitle" />
      <input type="text" name="artworkSlug" />
      <input type="text" name="series" />
      <input type="text" name="pageUrl" />

      <input type="text" name="name" />
      <input type="email" name="email" />
      <textarea name="message"></textarea>

      <button type="submit">Send</button>
    </form>
  </body>
</html>